{
  "manifest_version": 3,
  "name": "My Extension",
  "version": "1.0",
  "description": "A friendly, educational Chrome extension.",
  "action": {
    "default_popup": "popup.html",
    "default_title": "Druid"
  },
  "permissions": [
    "activeTab",
    "storage",
    "tabs",
    "scripting"
  ],
  "host_permissions": [
    "<all_urls>",
    "https://huggingface.co/*",
    "https://generativelanguage.googleapis.com/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["http://*/*", "https://*/*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "content_security_policy": {
  "extension_pages": "script-src 'self'; object-src 'self'"
  }
}
